# U2D2: porta seriale, nome stabile e tweak della latenza
SUBSYSTEM=="tty", ATTRS{serial}=="FT3MIEP8", \
  ENV{ID_MM_DEVICE_IGNORE}="1", \
  ATTR{device/latency_timer}="1", \
  SYMLINK+="ttyU2D2"

# U2D2: disabilita autosuspend sul device USB
SUBSYSTEM=="usb", ATTRS{serial}=="FT3MIEP8", \
  TEST=="power/control", ATTR{power/control}="on"

SUBSYSTEM=="usb", ATTRS{serial}=="FT3MIEP8", \
  TEST=="power/autosuspend", ATTR{power/autosuspend}="-1"

SUBSYSTEM=="usb", ATTRS{serial}=="FT3MIEP8", \
  TEST=="power/autosuspend_delay_ms", ATTR{power/autosuspend_delay_ms}="0"
